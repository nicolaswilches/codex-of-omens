---
/**
 * Pixel art EV charging station icon — forest greens and water tones
 * 16x16 grid
 */
interface Props {
  size?: number;
}
const { size = 48 } = Astro.props;
---

<svg width={size} height={size} viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="16" height="16" fill="#F2F0E5" rx="2" />

  <!-- Charging station body -->
  <rect x="3" y="3" width="6" height="9" fill="#4A7C59" />
  <rect x="3" y="2" width="6" height="1" fill="#3A6449" />
  <rect x="3" y="12" width="6" height="1" fill="#3A6449" />

  <!-- Screen on station -->
  <rect x="4" y="4" width="4" height="3" fill="#24837B" />
  <rect x="5" y="5" width="2" height="1" fill="#3AA99F" />

  <!-- Plug symbol -->
  <rect x="5" y="8" width="2" height="1" fill="#AD8301" />
  <rect x="5" y="9" width="1" height="2" fill="#8B6914" />
  <rect x="6" y="9" width="1" height="2" fill="#8B6914" />

  <!-- Cable going right -->
  <rect x="9" y="7" width="1" height="1" fill="#575653" />
  <rect x="10" y="7" width="1" height="1" fill="#575653" />
  <rect x="11" y="7" width="1" height="1" fill="#575653" />
  <rect x="11" y="8" width="1" height="1" fill="#575653" />
  <rect x="11" y="9" width="1" height="1" fill="#575653" />

  <!-- Small car silhouette -->
  <rect x="10" y="10" width="4" height="2" fill="#6F6E69" />
  <rect x="11" y="9" width="2" height="1" fill="#6F6E69" />
  <rect x="10" y="12" width="1" height="1" fill="#403E3C" />
  <rect x="13" y="12" width="1" height="1" fill="#403E3C" />

  <!-- Ground line -->
  <rect x="2" y="13" width="12" height="1" fill="#DAD8CE" />
</svg>
