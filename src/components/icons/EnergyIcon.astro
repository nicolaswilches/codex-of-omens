---
/**
 * Pixel art lightning bolt / power grid icon — warm yellows and earth tones
 * 16x16 grid
 */
interface Props {
  size?: number;
}
const { size = 48 } = Astro.props;
---

<svg width={size} height={size} viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="16" height="16" fill="#F2F0E5" rx="2" />

  <!-- Lightning bolt - earth/amber tones -->
  <rect x="8" y="1" width="2" height="1" fill="#AD8301" />
  <rect x="7" y="2" width="2" height="1" fill="#AD8301" />
  <rect x="6" y="3" width="2" height="1" fill="#AD8301" />
  <rect x="5" y="4" width="2" height="1" fill="#AD8301" />
  <rect x="4" y="5" width="2" height="1" fill="#8B6914" />
  <rect x="4" y="6" width="5" height="1" fill="#8B6914" />
  <rect x="7" y="7" width="2" height="1" fill="#AD8301" />
  <rect x="7" y="8" width="2" height="1" fill="#AD8301" />
  <rect x="6" y="9" width="2" height="1" fill="#DA702C" />
  <rect x="6" y="10" width="5" height="1" fill="#DA702C" />
  <rect x="9" y="11" width="2" height="1" fill="#BC5215" />
  <rect x="8" y="12" width="2" height="1" fill="#BC5215" />
  <rect x="7" y="13" width="2" height="1" fill="#BC5215" />
  <rect x="6" y="14" width="2" height="1" fill="#BC5215" />

  <!-- Small spark pixels -->
  <rect x="3" y="3" width="1" height="1" fill="#E6E4D9" />
  <rect x="12" y="8" width="1" height="1" fill="#E6E4D9" />
  <rect x="2" y="7" width="1" height="1" fill="#DAD8CE" />
</svg>
