  <rect x="32" y="32" width="6" height="2" fill="#BC5215" />

  <!-- Shaft highlight (left edge) -->
  <rect x="32" y="6" width="1" height="28" fill="#DA702C" />

  <!-- Shaft shadow (right edge) -->
  <rect x="37" y="6" width="1" height="28" fill="#943F0F" />

  <!-- Arrow tip -->
  <rect x="27" y="34" width="16" height="1" fill="#D4621E" />
  <rect x="28" y="35" width="14" height="1" fill="#BC5215" />
  <rect x="29" y="36" width="12" height="1" fill="#BC5215" />
  <rect x="30" y="37" width="10" height="1" fill="#BC5215" />
  <rect x="31" y="38" width="8" height="1" fill="#BC5215" />
  <rect x="32" y="39" width="6" height="1" fill="#A84812" />
  <rect x="33" y="40" width="4" height="1" fill="#A84812" />
  <rect x="34" y="41" width="2" height="1" fill="#943F0F" />

  <!-- Arrow tip highlight (left edge) -->
  <rect x="27" y="34" width="1" height="1" fill="#DA702C" />
  <rect x="28" y="35" width="1" height="1" fill="#DA702C" />
  <rect x="29" y="36" width="1" height="1" fill="#DA702C" />
  <rect x="30" y="37" width="1" height="1" fill="#DA702C" />
  <rect x="31" y="38" width="1" height="1" fill="#DA702C" />

  <!-- Arrow tip shadow (right edge) -->
  <rect x="42" y="34" width="1" height="1" fill="#943F0F" />
  <rect x="41" y="35" width="1" height="1" fill="#943F0F" />
  <rect x="40" y="36" width="1" height="1" fill="#943F0F" />
  <rect x="39" y="37" width="1" height="1" fill="#943F0F" />
  <rect x="38" y="38" width="1" height="1" fill="#943F0F" />

  <!-- Subtle grid dots for texture -->
  <rect x="3" y="3" width="1" height="1" fill="#E6E4D9" />
  <rect x="45" y="3" width="1" height="1" fill="#E6E4D9" />
  <rect x="3" y="44" width="1" height="1" fill="#E6E4D9" />
  <rect x="45" y="44" width="1" height="1" fill="#E6E4D9" />
  <rect x="24" y="24" width="1" height="1" fill="#DAD8CE" />
</svg>
