---
/**
 * Pixel art dual arrows icon — green up arrow, red down arrow
 * 48x48 grid, detailed pixel art with shading and depth
 */
interface Props {
  size?: number;
}
const { size = 144 } = Astro.props;
---

<svg width={size} height={size} viewBox="0 0 48 48" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="48" height="48" fill="#F2F0E5" rx="4" />

  <!-- === GREEN UP ARROW (left side) === -->

  <!-- Arrow tip -->
  <rect x="12" y="6" width="2" height="1" fill="#3D6B4A" />
  <rect x="11" y="7" width="4" height="1" fill="#3D6B4A" />
  <rect x="10" y="8" width="6" height="1" fill="#4A7C59" />
  <rect x="9" y="9" width="8" height="1" fill="#4A7C59" />
  <rect x="8" y="10" width="10" height="1" fill="#4A7C59" />
  <rect x="7" y="11" width="12" height="1" fill="#4A7C59" />
  <rect x="6" y="12" width="14" height="1" fill="#5A8E68" />
  <rect x="5" y="13" width="16" height="1" fill="#5A8E68" />

  <!-- Arrow tip highlight (left edge) -->
  <rect x="5" y="13" width="1" height="1" fill="#6B9E7A" />
  <rect x="6" y="12" width="1" height="1" fill="#6B9E7A" />
  <rect x="7" y="11" width="1" height="1" fill="#6B9E7A" />
  <rect x="8" y="10" width="1" height="1" fill="#6B9E7A" />
  <rect x="9" y="9" width="1" height="1" fill="#6B9E7A" />
  <rect x="10" y="8" width="1" height="1" fill="#6B9E7A" />
  <rect x="11" y="7" width="1" height="1" fill="#6B9E7A" />

  <!-- Arrow tip shadow (right edge) -->
  <rect x="20" y="13" width="1" height="1" fill="#3D6B4A" />
  <rect x="19" y="12" width="1" height="1" fill="#3D6B4A" />
  <rect x="18" y="11" width="1" height="1" fill="#3D6B4A" />
  <rect x="17" y="10" width="1" height="1" fill="#3D6B4A" />
  <rect x="16" y="9" width="1" height="1" fill="#3D6B4A" />

  <!-- Arrow shaft -->
  <rect x="10" y="14" width="6" height="2" fill="#4A7C59" />
  <rect x="10" y="16" width="6" height="2" fill="#4A7C59" />
  <rect x="10" y="18" width="6" height="2" fill="#5A8E68" />
  <rect x="10" y="20" width="6" height="2" fill="#5A8E68" />
  <rect x="10" y="22" width="6" height="2" fill="#4A7C59" />
  <rect x="10" y="24" width="6" height="2" fill="#4A7C59" />
  <rect x="10" y="26" width="6" height="2" fill="#5A8E68" />
  <rect x="10" y="28" width="6" height="2" fill="#5A8E68" />
  <rect x="10" y="30" width="6" height="2" fill="#4A7C59" />
  <rect x="10" y="32" width="6" height="2" fill="#4A7C59" />
  <rect x="10" y="34" width="6" height="2" fill="#5A8E68" />
  <rect x="10" y="36" width="6" height="2" fill="#5A8E68" />
  <rect x="10" y="38" width="6" height="2" fill="#4A7C59" />
  <rect x="10" y="40" width="6" height="2" fill="#4A7C59" />

  <!-- Shaft highlight (left edge) -->
  <rect x="10" y="14" width="1" height="28" fill="#6B9E7A" />

  <!-- Shaft shadow (right edge) -->
  <rect x="15" y="14" width="1" height="28" fill="#3D6B4A" />

  <!-- === RED DOWN ARROW (right side) === -->

  <!-- Arrow shaft -->
  <rect x="32" y="6" width="6" height="2" fill="#BC5215" />
  <rect x="32" y="8" width="6" height="2" fill="#BC5215" />
  <rect x="32" y="10" width="6" height="2" fill="#D4621E" />
  <rect x="32" y="12" width="6" height="2" fill="#D4621E" />
  <rect x="32" y="14" width="6" height="2" fill="#BC5215" />
  <rect x="32" y="16" width="6" height="2" fill="#BC5215" />
  <rect x="32" y="18" width="6" height="2" fill="#D4621E" />
  <rect x="32" y="20" width="6" height="2" fill="#D4621E" />
  <rect x="32" y="22" width="6" height="2" fill="#BC5215" />
  <rect x="32" y="24" width="6" height="2" fill="#BC5215" />
  <rect x="32" y="26" width="6" height="2" fill="#D4621E" />
  <rect x="32" y="28" width="6" height="2" fill="#D4621E" />
