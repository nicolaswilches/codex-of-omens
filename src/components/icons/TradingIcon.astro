---
/**
 * Pixel art candlestick chart icon — warm greens and clay tones
 * 16x16 grid, each "pixel" is a 2x2 rect for crispness
 */
interface Props {
  size?: number;
}
const { size = 48 } = Astro.props;
const s = size / 16; // scale factor
---

<svg width={size} height={size} viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="16" height="16" fill="#F2F0E5" rx="2" />

  <!-- Grid lines (subtle) -->
  <rect x="2" y="13" width="12" height="1" fill="#DAD8CE" />
  <rect x="2" y="10" width="12" height="1" fill="#E6E4D9" />
  <rect x="2" y="7" width="12" height="1" fill="#E6E4D9" />

  <!-- Candle 1 - green (up) -->
  <rect x="3" y="5" width="1" height="7" fill="#4A7C59" />
  <rect x="2" y="6" width="3" height="4" fill="#4A7C59" />

  <!-- Candle 2 - red (down) -->
  <rect x="6" y="3" width="1" height="8" fill="#BC5215" />
  <rect x="5" y="4" width="3" height="5" fill="#BC5215" />

  <!-- Candle 3 - green (up) -->
  <rect x="9" y="2" width="1" height="9" fill="#4A7C59" />
  <rect x="8" y="4" width="3" height="5" fill="#6B9E7A" />

  <!-- Candle 4 - green (up, tall) -->
  <rect x="12" y="1" width="1" height="10" fill="#4A7C59" />
  <rect x="11" y="3" width="3" height="6" fill="#4A7C59" />
</svg>
