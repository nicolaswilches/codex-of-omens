---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="metric-card rounded-md p-4 text-center" style="background-color: var(--accent); color: #FFFCF0;">
  <p class="text-2xl font-semibold">{value}</p>
  <p class="mt-1 text-xs opacity-85">{label}</p>
</div>
