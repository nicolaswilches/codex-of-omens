---
interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary';
  external?: boolean;
}

const { href, label, variant = 'primary', external = true } = Astro.props;

const styles = {
  primary: 'bg-ink-900 text-paper hover:bg-ink-700',
  secondary: 'border border-ink-200 text-ink-600 hover:border-ink-300 hover:text-ink-900',
};
---

<a
  href={href}
  class:list={[
    'inline-flex items-center gap-1.5 px-3.5 py-1.5 text-sm font-medium transition-colors',
    styles[variant],
  ]}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
>
  {label}
  {external && (
    <svg class="h-3.5 w-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  )}
</a>
