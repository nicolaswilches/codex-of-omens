---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="mx-auto max-w-5xl px-6 pb-12 pt-20">
  <h1 class="text-4xl font-bold tracking-tight text-navy-900 sm:text-5xl">
    {title}
  </h1>
  {subtitle && (
    <p class="mt-4 max-w-2xl text-lg text-navy-600">
      {subtitle}
    </p>
  )}
  <slot />
</section>
