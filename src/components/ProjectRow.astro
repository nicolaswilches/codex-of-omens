---
interface Props {
  title: string;
  tagline: string;
  tags: string[];
  status: 'complete' | 'in-progress' | 'coming-soon';
  date: Date;
  href: string;
  accent: 'orange' | 'lavender' | 'green' | 'blue';
  accentColor?: string;
  motif?: string;
}

const { title, tagline, tags, status, date, href, accent, accentColor, motif } = Astro.props;
const year = date.getFullYear();
const isComingSoon = status === 'coming-soon';

const statusLabel = {
  'complete': '',
  'in-progress': 'In progress',
  'coming-soon': 'Coming soon',
};

const statusColor = {
  'complete': '',
  'in-progress': 'text-earth',
  'coming-soon': 'text-ink-400',
};

const accentVar = accentColor ?? `var(--color-accent-${accent})`;
const tintVar = accentColor
  ? `color-mix(in srgb, ${accentColor} 12%, #FFFCF0)`
  : `var(--color-accent-${accent}-tint)`;
const rowStyle = `--accent: ${accentVar}; --accent-tint: ${tintVar};`;
---

<a
  href={isComingSoon ? undefined : href}
  style={rowStyle}
  class:list={[
    'project-row group flex gap-4 py-5 -mx-3 px-3 transition-colors',
    isComingSoon ? 'cursor-default opacity-50' : '',
  ]}
>
  <!-- Motif marker: per-project SVG via CSS mask, or flat accent square fallback -->
  {motif ? (
    <img src={motif} alt="" aria-hidden="true" class="mt-1 shrink-0 h-7 w-7" />
  ) : (
    <span
      aria-hidden="true"
      class="mt-1 shrink-0 h-7 w-7"
      style="background-color: var(--accent);"
    ></span>
  )}

  <div class="min-w-0">
    <div class="flex items-baseline gap-3 flex-wrap">
      <h3 class:list={[
        'font-medium',
        isComingSoon ? 'text-ink-400' : 'text-ink-900',
      ]}>
        {title}
      </h3>
      <span class="text-sm text-ink-300">{year}</span>
      {statusLabel[status] && (
        <span class:list={['text-xs font-medium', statusColor[status]]}>
          {statusLabel[status]}
        </span>
      )}
    </div>
    <p class="mt-1 text-sm text-ink-500 leading-relaxed">{tagline}</p>
    <div class="mt-2 flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="text-xs text-ink-500 border border-ink-150 px-2 py-0.5">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>

<style>
  .project-row:not(.cursor-default):hover {
    background-color: var(--accent-tint);
  }
</style>
