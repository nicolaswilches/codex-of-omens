---
interface Props {
  title: string;
  tagline: string;
  tags: string[];
  status: 'complete' | 'in-progress' | 'coming-soon';
  date: Date;
  href: string;
  icon: any;
}

const { title, tagline, tags, status, date, href, icon: Icon } = Astro.props;
const year = date.getFullYear();
const isComingSoon = status === 'coming-soon';

const statusLabel = {
  'complete': '',
  'in-progress': 'In progress',
  'coming-soon': 'Coming soon',
};

const statusColor = {
  'complete': '',
  'in-progress': 'text-earth',
  'coming-soon': 'text-ink-400',
};
---

<a
  href={isComingSoon ? undefined : href}
  class:list={[
    'group flex gap-4 py-5 -mx-3 px-3 rounded-lg transition-colors',
    isComingSoon ? 'cursor-default opacity-50' : 'hover:bg-paper-dark',
  ]}
>
  <!-- Pixel art icon -->
  <div class="shrink-0 mt-0.5">
    <div class="hidden sm:block"><Icon size={144} /></div>
    <div class="sm:hidden"><Icon size={120} /></div>
  </div>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <div class="flex items-baseline gap-3 flex-wrap">
      <h3 class:list={[
        'font-medium',
        isComingSoon ? 'text-ink-400' : 'text-ink-900',
      ]}>
        {title}
      </h3>
      <span class="text-sm text-ink-300">{year}</span>
      {statusLabel[status] && (
        <span class:list={['text-xs font-medium', statusColor[status]]}>
          {statusLabel[status]}
        </span>
      )}
    </div>
    <p class="mt-1 text-sm text-ink-500 leading-relaxed">{tagline}</p>
    <div class="mt-2 flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="text-xs text-ink-500 border border-ink-150 rounded-full px-2 py-0.5">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
