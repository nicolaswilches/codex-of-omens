---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  tagline: string;
  date: Date;
  updatedDate?: Date;
  status: 'complete' | 'in-progress' | 'coming-soon';
  heroImage: string;
  techStack: string[];
  tags: string[];
  githubUrl?: string;
  liveUrl?: string;
  accent: 'orange' | 'lavender' | 'green' | 'blue';
  accentColor?: string;
  bodyColor?: string;
  motif?: string;
  readingTime: number;
  headings: { depth: number; slug: string; text: string }[];
  prevProject?: { id: string; title: string } | null;
  nextProject?: { id: string; title: string } | null;
}

const base = import.meta.env.BASE_URL;
const {
  title, tagline, date, updatedDate, status,
  techStack, tags, githubUrl, liveUrl, accent, accentColor, bodyColor, motif, readingTime, headings,
  prevProject, nextProject,
} = Astro.props;

const accentVar = accentColor ?? `var(--color-accent-${accent})`;
const tintVar = accentColor
  ? `color-mix(in srgb, ${accentColor} 12%, #FFFCF0)`
  : `var(--color-accent-${accent}-tint)`;
const accentStyle = `--accent: ${accentVar}; --accent-tint: ${tintVar};${bodyColor ? ` --body-color: ${bodyColor};` : ''}`;

const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
const tocHeadings = headings.filter((h) => h.depth === 2);
const showToc = tocHeadings.length > 1;
---

<BaseLayout title={`${title} — Nicolás Higuera Wilches`} description={tagline}>
  <div style={accentStyle} class="project-scope">
  <!-- Reading progress bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-0.5 z-50" style="width: 0%; background-color: var(--accent);"></div>

  <!-- Desktop TOC sidebar (hidden while hero is in view) -->
  {showToc && (
    <aside id="toc-aside" class="hidden lg:block fixed z-40 opacity-0 pointer-events-none transition-opacity duration-200" style="left: 1rem; top: 50%; transform: translateY(-50%); width: 11rem;">
      <nav>
        <p class="text-xs font-medium text-ink-400 uppercase tracking-wider mb-3">On this page</p>
        <ul class="border-l border-ink-100 space-y-1">
          {tocHeadings.map((h) => (
            <li>
              <a href={`#${h.slug}`} data-toc-slug={h.slug} class="toc-link block pl-3 py-1 text-sm text-ink-400 hover:text-ink-900 transition-colors border-l-2 border-transparent -ml-px hover:border-[var(--accent)]">
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )}

  <div class="mx-auto max-w-[46em] px-6">
    <!-- Back link (on paper, above tinted hero) -->
    <a href={`${base}/`} class="inline-flex items-center gap-1 text-sm text-ink-400 hover:text-ink-900 transition-colors mb-6 mt-2">
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Projects
    </a>

    <!-- Hero: full accent background, paper text -->
    <section id="project-hero" class="px-6 py-8 sm:py-10 -mx-6" style="background-color: var(--accent); color: #FFFCF0;">
      <header>
        {motif && (
          <img src={motif} alt="" aria-hidden="true" class="block h-12 w-12 mb-4" />
        )}
        <h1 class="text-2xl font-semibold sm:text-3xl">{title}</h1>
        <p class="mt-3 leading-relaxed" style="color: #FFFCF0; opacity: 0.92;">{tagline}</p>

        <div class="mt-1.5 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm" style="color: #FFFCF0; opacity: 0.8;">
          <span>{dateStr}</span>
          <span>&middot;</span>
          <span>{readingTime} min read</span>
        </div>

        {(liveUrl || githubUrl) && (
          <div class="mt-5 flex flex-wrap gap-3">
            {liveUrl && (
              <a href={liveUrl} target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3.5 py-1.5 text-sm font-medium transition-colors hover:bg-paper"
                style="color: #FFFCF0; border: 1px solid #FFFCF0;"
                onmouseover="this.style.color='var(--accent)'"
                onmouseout="this.style.color='#FFFCF0'">
                Live app
                <svg class="h-3.5 w-3.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              </a>
            )}
            {githubUrl && (
              <a href={githubUrl} target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3.5 py-1.5 text-sm font-medium transition-colors hover:bg-paper"
                style="color: #FFFCF0; border: 1px solid #FFFCF0;"
                onmouseover="this.style.color='var(--accent)'"
                onmouseout="this.style.color='#FFFCF0'">
                GitHub
                <svg class="h-3.5 w-3.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              </a>
            )}
          </div>
        )}

        <div class="mt-5 flex flex-wrap gap-1.5">
          {techStack.map((tech) => (
            <span class="text-xs px-2 py-0.5" style="color: #FFFCF0; border: 1px solid rgba(255,252,240,0.6);">
              {tech}
            </span>
          ))}
        </div>
      </header>
    </section>

    <div class="pt-4">

      <!-- Mobile TOC -->
      {showToc && (
        <details class="lg:hidden mt-6 border border-ink-100 px-4 py-3">
          <summary class="text-sm font-medium text-ink-500 cursor-pointer select-none">Table of contents</summary>
          <ul class="mt-3 space-y-1.5">
            {tocHeadings.map((h) => (
              <li><a href={`#${h.slug}`} class="text-sm text-ink-400 hover:text-ink-900 transition-colors">{h.text}</a></li>
            ))}
          </ul>
        </details>
      )}

      <!-- Content -->
      <article class:list={['prose max-w-none py-10', bodyColor && 'body-override']}>
        <slot />
      </article>

      <!-- Prev/Next navigation -->
      <div class="border-t border-ink-100 pt-8 pb-4">
        <div class="flex justify-between items-start gap-4">
          {prevProject ? (
            <a href={`${base}/projects/${prevProject.id}/`} class="group text-left">
              <span class="text-xs text-ink-300 block">Previous</span>
              <span class="text-sm text-ink-400 group-hover:text-ink-900 transition-colors flex items-center gap-1">
                <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
                {prevProject.title}
              </span>
            </a>
          ) : <div />}
          {nextProject ? (
            <a href={`${base}/projects/${nextProject.id}/`} class="group text-right ml-auto">
              <span class="text-xs text-ink-300 block">Next</span>
              <span class="text-sm text-ink-400 group-hover:text-ink-900 transition-colors flex items-center gap-1">
                {nextProject.title}
                <svg class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ) : <div />}
        </div>
        <a href={`${base}/`} class="inline-flex items-center gap-1 text-sm text-ink-400 hover:text-ink-900 transition-colors mt-6">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          All projects
        </a>
      </div>
    </div>

  </div>
  </div>

  <!-- Progress bar script -->
  <script is:inline>
    function initProgress() {
      var bar = document.getElementById('reading-progress');
      if (!bar) return;
      function update() {
        var scrollTop = window.scrollY;
        var docHeight = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = docHeight > 0 ? (scrollTop / docHeight * 100) + '%' : '0%';
      }
      window.addEventListener('scroll', update, { passive: true });
      update();
    }
    initProgress();
    document.addEventListener('astro:after-swap', initProgress);

    function initTocVisibility() {
      var toc = document.getElementById('toc-aside');
      var hero = document.getElementById('project-hero');
      if (!toc || !hero || !('IntersectionObserver' in window)) return;
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          var hide = entry.isIntersecting;
          toc.classList.toggle('opacity-0', hide);
          toc.classList.toggle('pointer-events-none', hide);
          toc.classList.toggle('opacity-100', !hide);
        });
      }, { rootMargin: '0px 0px -80% 0px' });
      obs.observe(hero);
    }

    function initTocActive() {
      if (!('IntersectionObserver' in window)) return;
      var links = document.querySelectorAll('.toc-link[data-toc-slug]');
      if (!links.length) return;
      var bySlug = {};
      links.forEach(function(a) { bySlug[a.getAttribute('data-toc-slug')] = a; });
      var headings = [];
      Object.keys(bySlug).forEach(function(slug) {
        var el = document.getElementById(slug);
        if (el) headings.push(el);
      });
      if (!headings.length) return;
      var visible = new Set();
      function paint() {
        links.forEach(function(a) { a.classList.remove('toc-active'); });
        if (!visible.size) return;
        var first = null;
        headings.forEach(function(h) { if (!first && visible.has(h.id)) first = h.id; });
        if (first && bySlug[first]) bySlug[first].classList.add('toc-active');
      }
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) visible.add(entry.target.id);
          else visible.delete(entry.target.id);
        });
        paint();
      }, { rootMargin: '-10% 0px -70% 0px' });
      headings.forEach(function(h) { obs.observe(h); });
    }

    initTocVisibility();
    initTocActive();
    document.addEventListener('astro:after-swap', function() {
      initTocVisibility();
      initTocActive();
    });
  </script>
</BaseLayout>
