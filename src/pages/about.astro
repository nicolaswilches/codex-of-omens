---
import BaseLayout from '../layouts/BaseLayout.astro';

---

<BaseLayout
  title="About — Nicolás Higuera Wilches"
  description="I'm a data scientist based in Madrid. I'm currently exploring the applications of machine learning models in fields such as renewable energy, transportation and smart cities"
>
  <div class="mx-auto max-w-[46em] px-6">
    <!-- Hero -->
    <section class="pb-12">
      <h1 class="text-3xl font-semibold text-ink-900 sm:text-4xl">Nicolás Higuera Wilches</h1>
      <p class="mt-2 text-lg text-ink-500">Data Scientist</p>
      <div class="mt-4 flex items-center gap-4">
        <a href="https://github.com/nicolaswilches" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-ink-400 hover:text-ink-900 transition-colors">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://linkedin.com/in/nicolaswilches" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-ink-400 hover:text-ink-900 transition-colors">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="mailto:nicolaswilches@icloud.com" aria-label="Email" class="text-ink-400 hover:text-ink-900 transition-colors">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
        </a>
      </div>
    </section>

    <!-- Bio -->
    <section class="pb-12">
      <div class="space-y-5 text-ink-600 leading-relaxed">
        <p>
          I enjoy the full arc of a data science project: understanding the problem, engineering the features,
          training the model, and deploying it as a real service people can use. Most of my recent work sits
          at the intersection of machine learning and software engineering — containerized APIs, CI/CD pipelines,
          and monitoring systems that keep models honest after deployment.
        </p>
        <p>
          I'm currently completing a Master's in Business Analytics and Big Data at IE in Madrid.
          Before that, I worked in analytics and data roles where I learned that a model only matters
          if someone can act on its output.
        </p>
      </div>
    </section>

    <!-- Education -->
    <section class="pb-12">
      <h2 class="text-sm font-medium text-ink-400 uppercase tracking-wider mb-6">Education</h2>
      <div>
        <p class="font-medium text-ink-900">Master's in Business Analytics and Big Data</p>
        <p class="text-sm text-ink-500 mt-1">IE School of Science and Technology · Madrid · 2025–2026</p>
      </div>
    </section>

    <!-- Contact -->
    <section class="pb-4">
      <h2 class="text-sm font-medium text-ink-400 uppercase tracking-wider mb-6">Contact</h2>
      <div class="flex flex-wrap gap-5">
        <a href="https://github.com/nicolaswilches" target="_blank" rel="noopener noreferrer"
          class="text-sm text-ink-500 hover:text-ink-900 transition-colors underline underline-offset-2 decoration-ink-200">
          GitHub
        </a>
        <a href="https://linkedin.com/in/nicolaswilches" target="_blank" rel="noopener noreferrer"
          class="text-sm text-ink-500 hover:text-ink-900 transition-colors underline underline-offset-2 decoration-ink-200">
          LinkedIn
        </a>
        <a href="mailto:nicolaswilches@icloud.com"
          class="text-sm text-ink-500 hover:text-ink-900 transition-colors underline underline-offset-2 decoration-ink-200">
          nicolaswilches@icloud.com
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
