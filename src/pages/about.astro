---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = {
  'Languages & Core': ['Python', 'SQL', 'R', 'Bash'],
  'Machine Learning & Data': ['scikit-learn', 'LightGBM', 'pandas', 'Polars', 'NumPy', 'statsmodels', 'PySpark'],
  'Visualization': ['Plotly', 'Matplotlib', 'Streamlit', 'Folium'],
  'Engineering': ['FastAPI', 'Docker', 'GitHub Actions', 'MLflow', 'Evidently'],
  'Geospatial': ['GeoPandas', 'Shapely', 'Leaflet'],
};
---

<BaseLayout
  title="About — Nicolás Higuera Wilches"
  description="I'm a data scientist based in Madrid. I'm currently exploring the applications of machine learning models in fields such as renewable energy, transportation and smart cities"
>
  <div class="mx-auto max-w-[40em] px-6">
    <!-- Bio -->
    <section class="pb-12">
      <div class="space-y-5 text-ink-600 leading-relaxed">
        <p>
          I enjoy the full arc of a data science project: understanding the problem, engineering the features,
          training the model, and deploying it as a real service people can use. Most of my recent work sits
          at the intersection of machine learning and software engineering — containerized APIs, CI/CD pipelines,
          and monitoring systems that keep models honest after deployment.
        </p>
        <p>
          I'm currently completing a Master's in Business Analytics and Big Data at IE in Madrid.
          Before that, I worked in analytics and data roles where I learned that a model only matters
          if someone can act on its output.
        </p>
      </div>
    </section>

    <!-- Skills -->
    <section class="pb-12">
      <h2 class="text-sm font-medium text-ink-400 uppercase tracking-wider mb-6">Tools & Skills</h2>
      <div class="space-y-5">
        {Object.entries(skills).map(([category, items]) => (
          <div>
            <h3 class="text-sm font-medium text-ink-700 mb-2">{category}</h3>
            <div class="flex flex-wrap gap-1.5">
              {items.map((skill) => (
                <span class="text-xs text-ink-500 border border-ink-150 rounded-full px-2.5 py-0.5">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section class="pb-12">
      <h2 class="text-sm font-medium text-ink-400 uppercase tracking-wider mb-6">Education</h2>
      <div>
        <p class="font-medium text-ink-900">Master's in Business Analytics and Big Data</p>
        <p class="text-sm text-ink-500 mt-1">IE School of Science and Technology · Madrid · 2025–2026</p>
      </div>
    </section>

    <!-- Contact -->
    <section class="pb-4">
      <h2 class="text-sm font-medium text-ink-400 uppercase tracking-wider mb-6">Contact</h2>
      <div class="flex flex-wrap gap-5">
        <a href="https://github.com/nicolaswilches" target="_blank" rel="noopener noreferrer"
          class="text-sm text-ink-500 hover:text-ink-900 transition-colors underline underline-offset-2 decoration-ink-200">
          GitHub
        </a>
        <a href="https://linkedin.com/in/nicolaswilches" target="_blank" rel="noopener noreferrer"
          class="text-sm text-ink-500 hover:text-ink-900 transition-colors underline underline-offset-2 decoration-ink-200">
          LinkedIn
        </a>
        <a href="mailto:nicolaswilches@icloud.com"
          class="text-sm text-ink-500 hover:text-ink-900 transition-colors underline underline-offset-2 decoration-ink-200">
          nicolaswilches@icloud.com
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
